{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/nouveau/layout,_N_T_/dashboard/nouveau/page,_N_T_/dashboard/nouveau"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/nouveau/__PAGE__",
    "/dashboard/nouveau",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}